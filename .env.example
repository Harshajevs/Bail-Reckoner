# Copy to .env and adjust. Every value has a working default for local
# development — the app runs with no .env at all.

# --- Core ---
# SQLite (default, zero setup):
#DATABASE_URL=sqlite:///./bail_reckoner.db
# PostgreSQL (production):
#DATABASE_URL=postgresql://user:password@localhost:5432/bail_reckoner

# REQUIRED in production: long random string used to sign JWTs
# Generate one: python -c "import secrets; print(secrets.token_hex(32))"
#SECRET_KEY=

# Token lifetime in minutes (default 720 = 12h)
#ACCESS_TOKEN_EXPIRE_MINUTES=720

# Extra allowed CORS origins, comma-separated. Not needed when the app
# serves its own frontend (same origin).
#CORS_ORIGINS=

# --- AI provider ---
# rule_based (default, no credentials) | ollama | openrouter | openai
#AI_PROVIDER=rule_based

# Ollama (free, local — https://ollama.com)
#OLLAMA_BASE_URL=http://localhost:11434
#OLLAMA_MODEL=llama3.2

# OpenRouter (free-tier models — https://openrouter.ai)
#OPENROUTER_API_KEY=
#OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free

# OpenAI (optional, paid)
#OPENAI_API_KEY=
#OPENAI_MODEL=gpt-4o-mini
